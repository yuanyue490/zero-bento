---
import BasicLayout from "../layouts/BasicLayout.astro";
import { getCollection } from "astro:content";
import HomeSidebar from "../components/home/HomeSidebar.astro";
import AboutModal from "../components/home/AboutModal.astro";
import HeroIdentity from "../components/home/HeroIdentity.astro";
import ProfilePanel from "../components/home/ProfilePanel.astro";
import SelectedWorks from "../components/home/SelectedWorks.astro";
import HomeFooter from "../components/home/HomeFooter.astro";
import {
  fallbackSelectedWorks,
  homeAbout,
  homeAboutDetail,
  homeHero,
  homeNavigation,
  homeSkills,
  homeSocialLinks,
} from "../data/home";

const posts = (await getCollection("blog"))?.sort(
  (blogEntryA, blogEntryB) =>
    (blogEntryB.data.pubDate || new Date()).getTime() -
    (blogEntryA.data.pubDate || new Date()).getTime()
);

const thoughts = posts.slice(0, 3).map((post) => ({
  title: post.data.title || "Untitled",
  date: post.data.pubDate || new Date(),
  href: `/blog/${post.id}`,
}));
---

<BasicLayout
  page="home"
  title="Zero Yue - 产品设计"
  description="产品设计,UI设计,交互设计,用户体验设计,视觉设计,设计管理"
>
  <HomeSidebar navItems={homeNavigation} socialLinks={homeSocialLinks} />
  <AboutModal detail={homeAboutDetail} />

  <main class="home-page">
    <div class="home-page__visual" aria-hidden="true">
      <div class="home-page__portrait-glow"></div>
      <img src={homeHero.portraitImage} alt="" class="home-page__portrait" />
    </div>

    <section class="home-page__left">
      <HeroIdentity {...homeHero} />
      <SelectedWorks works={fallbackSelectedWorks} />
    </section>

    <section class="home-page__right">
      <ProfilePanel about={homeAbout} skills={homeSkills} thoughts={thoughts} />
    </section>

    <HomeFooter />
  </main>
</BasicLayout>

<style>
  :global(html) {
    background: #030712;
  }

  .home-page {
    position: relative;
    height: 100svh;
    min-height: 42rem;
    overflow: hidden;
    background:
      radial-gradient(circle at 61% 17%, rgba(65, 80, 169, 0.34), transparent 34rem),
      radial-gradient(circle at 86% 54%, rgba(54, 71, 156, 0.2), transparent 31rem),
      linear-gradient(90deg, #030711 0%, #070e1e 46%, #10182d 100%);
    color: #f7f8ff;
    padding-left: 9.4rem;
    padding-right: clamp(2rem, 5vw, 5rem);
    display: grid;
    grid-template-columns: minmax(34rem, 1fr) minmax(17rem, 22rem);
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  .home-page::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(180deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 7rem 7rem;
    mask-image: linear-gradient(90deg, transparent, #000 16%, #000 84%, transparent);
    opacity: 0.2;
  }

  .home-page__left,
  .home-page__right,
  .home-page__visual {
    position: relative;
    z-index: 1;
  }

  .home-page__left {
    min-width: 0;
    padding-bottom: 2rem;
  }

  .home-page__right {
    min-height: 100svh;
    display: grid;
  }

  .home-page__visual {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .home-page__portrait {
    position: absolute;
    left: 36%;
    bottom: 0;
    width: auto;
    height: 100svh;
    min-height: 42rem;
    max-width: none;
    object-fit: contain;
    object-position: bottom center;
    filter: drop-shadow(0 0 70px rgba(80, 96, 210, 0.22));
    opacity: 0.94;
  }

  .home-page__portrait-glow {
    position: absolute;
    left: 34%;
    top: -18vh;
    width: min(54vw, 62rem);
    min-width: 38rem;
    height: 82vh;
    border-radius: 48% 52% 58% 42%;
    background:
      radial-gradient(ellipse at 54% 0%, rgba(244, 247, 255, 0.38) 0%, rgba(151, 164, 255, 0.24) 20%, transparent 54%),
      radial-gradient(ellipse at 50% 22%, rgba(92, 108, 232, 0.24) 0%, rgba(54, 69, 178, 0.12) 34%, transparent 68%),
      linear-gradient(180deg, rgba(210, 218, 255, 0.2) 0%, rgba(96, 112, 255, 0.12) 38%, rgba(18, 27, 72, 0) 82%);
    filter: blur(44px);
    opacity: 0.88;
    transform: rotate(7deg);
  }

  .home-page__portrait-glow::before,
  .home-page__portrait-glow::after {
    content: "";
    position: absolute;
    inset: auto;
    border-radius: 999px;
    pointer-events: none;
  }

  .home-page__portrait-glow::before {
    left: 38%;
    top: 0;
    width: 24%;
    height: 72%;
    background: linear-gradient(180deg, rgba(245, 248, 255, 0.24), rgba(111, 126, 255, 0.08) 58%, transparent);
    filter: blur(34px);
    transform: skewX(-13deg);
  }

  .home-page__portrait-glow::after {
    left: 26%;
    top: 38%;
    width: 46%;
    height: 42%;
    background: radial-gradient(ellipse at center, rgba(82, 96, 220, 0.18), transparent 66%);
    filter: blur(58px);
  }

  @media (max-width: 1180px) {
    .home-page {
      grid-template-columns: minmax(0, 1fr) minmax(15rem, 18rem);
      padding-left: 8.2rem;
      padding-right: 2rem;
    }

    .home-page__portrait {
      left: 38%;
      width: auto;
      min-width: 0;
      opacity: 0.74;
    }

    .home-page__portrait-glow {
      left: 30%;
      opacity: 0.72;
    }
  }

  @media (max-width: 1020px) {
    .home-page {
      height: auto;
      min-height: 100vh;
      overflow-x: clip;
      overflow-y: visible;
      grid-template-columns: 1fr;
      gap: 3rem;
      padding: 4.75rem 1.25rem 0;
    }

    .home-page__right {
      min-height: auto;
      grid-template-columns: minmax(0, 1fr) minmax(17rem, 22rem);
      align-items: start;
      gap: 2rem;
    }

    .home-page__portrait {
      top: 3.95rem;
      left: auto;
      right: -7rem;
      bottom: auto;
      width: 31rem;
      height: auto;
      min-height: 0;
      max-height: none;
      min-width: 0;
      opacity: 0.36;
    }

    .home-page__portrait-glow {
      left: auto;
      right: -12rem;
      top: -7rem;
      width: 35rem;
      min-width: 0;
      height: 36rem;
      opacity: 0.48;
      filter: blur(38px);
    }
  }

  @media (max-width: 760px) {
    .home-page {
      padding: 4.5rem 1rem 0;
    }

    .home-page__right {
      grid-template-columns: 1fr;
    }

    .home-page__portrait {
      top: 3.85rem;
      right: -8.5rem;
      width: min(28rem, 118vw);
      opacity: 0.26;
    }

    .home-page__portrait-glow {
      top: -5rem;
      right: -12rem;
      width: 28rem;
      height: 31rem;
      opacity: 0.38;
    }
  }
</style>
