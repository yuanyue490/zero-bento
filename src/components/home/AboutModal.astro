---
import { Icon } from "astro-icon/components";

interface Props {
  detail: {
    title: string;
    intro: string;
    skillIntro: string;
    skills: string[];
    paragraphs: string[];
    socials: {
      label: string;
      href: string;
      icon: string;
    }[];
  };
}

const { detail } = Astro.props;
---

<div class="about-modal" data-about-modal aria-hidden="true">
  <button type="button" class="about-modal__backdrop" aria-label="关闭关于我弹窗" data-about-modal-close></button>
  <section class="about-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="about-modal-title">
    <button type="button" class="about-modal__close" aria-label="关闭关于我弹窗" data-about-modal-close>×</button>

    <p class="about-modal__eyebrow">Profile</p>
    <h2 id="about-modal-title">{detail.title}</h2>

    <div class="about-modal__body">
      <p>{detail.intro}</p>
      <p>{detail.skillIntro}</p>
      <ul>
        {detail.skills.map((skill) => <li>{skill}</li>)}
      </ul>
      {detail.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      <div class="about-modal__socials" aria-label="社交平台">
        {detail.socials.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer">
            <Icon name={social.icon} />
            <span>{social.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</div>

<script>
  const aboutModal = document.querySelector("[data-about-modal]");
  const aboutModalTriggers = document.querySelectorAll("[data-about-modal-trigger]");
  const aboutModalCloseControls = document.querySelectorAll("[data-about-modal-close]");

  const openAboutModal = () => {
    aboutModal?.classList.add("is-visible");
    aboutModal?.setAttribute("aria-hidden", "false");
    document.documentElement.classList.add("has-about-modal");
  };

  const closeAboutModal = () => {
    aboutModal?.classList.remove("is-visible");
    aboutModal?.setAttribute("aria-hidden", "true");
    document.documentElement.classList.remove("has-about-modal");
  };

  aboutModalTriggers.forEach((trigger) => {
    trigger.addEventListener("click", (event) => {
      event.preventDefault();
      openAboutModal();
    });
  });

  aboutModalCloseControls.forEach((control) => {
    control.addEventListener("click", closeAboutModal);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeAboutModal();
    }
  });
</script>

<style>
  :global(html.has-about-modal) {
    overflow: hidden;
  }

  .about-modal {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 180ms ease, visibility 180ms ease;
  }

  .about-modal.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .about-modal__backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    background: rgba(2, 6, 16, 0.68);
    backdrop-filter: blur(12px);
  }

  .about-modal__dialog {
    position: relative;
    width: min(35rem, calc(100vw - 2rem));
    max-height: min(46rem, calc(100svh - 2rem));
    overflow: auto;
    padding: clamp(1.35rem, 3.4vw, 2.15rem);
    border: 1px solid rgba(130, 146, 214, 0.24);
    border-radius: 0.55rem;
    background: rgba(7, 12, 26, 0.96);
    box-shadow: 0 2rem 5rem rgba(0, 0, 0, 0.5), 0 0 4rem rgba(92, 108, 232, 0.12);
    transform: translateY(0.8rem) scale(0.98);
    transition: transform 180ms ease;
  }

  .about-modal.is-visible .about-modal__dialog {
    transform: translateY(0) scale(1);
  }

  .about-modal__close {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border: 1px solid rgba(247, 248, 255, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(247, 248, 255, 0.78);
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
  }

  .about-modal__close:hover {
    color: #fff;
    background: rgba(124, 132, 255, 0.16);
  }

  .about-modal__eyebrow {
    margin: 0 0 0.7rem;
    color: #6972ff;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .about-modal h2 {
    margin: 0 0 1.1rem;
    color: #f7f8ff;
    font-family: "CabinetGrotesk", "Satoshi", sans-serif;
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .about-modal__body {
    display: grid;
    gap: 0.72rem;
  }

  .about-modal__body p,
  .about-modal__body li {
    margin: 0;
    color: rgba(222, 227, 255, 0.72);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .about-modal__body ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.45rem 1rem;
    margin: 0.1rem 0 0.35rem;
    padding: 0;
    list-style: none;
  }

  .about-modal__body li {
    position: relative;
    padding-left: 1rem;
    color: rgba(240, 243, 255, 0.84);
  }

  .about-modal__body li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.72em;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: #7d86ff;
    box-shadow: 0 0 12px #727bff;
  }

  .about-modal__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.45rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(130, 146, 214, 0.18);
  }

  .about-modal__socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    min-height: 2.15rem;
    padding: 0 0.78rem;
    border: 1px solid rgba(247, 248, 255, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.035);
    color: rgba(240, 243, 255, 0.78);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: border-color 160ms ease, background 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .about-modal__socials a:hover {
    border-color: rgba(125, 134, 255, 0.48);
    background: rgba(125, 134, 255, 0.12);
    color: #fff;
    transform: translateY(-1px);
  }

  .about-modal__socials :global(svg) {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  @media (max-width: 560px) {
    .about-modal {
      padding: 1rem;
    }

    .about-modal__body ul {
      grid-template-columns: 1fr;
    }
  }
</style>
